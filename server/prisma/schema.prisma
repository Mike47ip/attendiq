// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String               @id @default(cuid())
  name            String
  email           String               @unique
  role            String               // "staff" | "manager"
  dept            String
  avatarInitials  String
  color           String               @default("#6366f1")
  officeId        String?
  office          Office?              @relation(fields: [officeId], references: [id])
  credentials     WebAuthnCredential[]
  attendance      Attendance[]
  challenge       WebAuthnChallenge?
  createdAt       DateTime             @default(now())
}

model Office {
  id           String       @id @default(cuid())
  name         String
  lat          Float
  lng          Float
  radiusMetres Int          @default(150)
  users        User[]
  attendance   Attendance[]
}

// Stores one registered biometric credential per device per user
model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  credentialId String   @unique  // base64url — unique device identifier
  publicKey    String            // base64url — used to verify future logins
  counter      Int      @default(0)  // increments each use, detects clones
  deviceType   String?           // "platform" | "cross-platform"
  createdAt    DateTime @default(now())
}

// Temporary challenge storage — deleted after use
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  challenge String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Attendance {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  date               String   // "YYYY-MM-DD"
  clockIn            String   // "HH:MM"
  clockOut           String?  // optional
  status             String   // "on-time" | "late"
  lat                Float
  lng                Float
  accuracy           Float    // GPS accuracy in metres
  gpsVerified        Boolean  @default(false)
  biometricVerified  Boolean  @default(false)
  officeId           String?
  office             Office?  @relation(fields: [officeId], references: [id])
  createdAt          DateTime @default(now())

  @@unique([userId, date])   // one record per user per day
}
